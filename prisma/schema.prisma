generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ─────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Transactions ──────────────────────────────────────────

enum TransactionType {
  income
  expense
  transfer
}

model Transaction {
  id       String          @id @default(uuid())
  title    String
  amount   Float
  type     TransactionType
  category String
  date     String          // ISO date string (YYYY-MM-DD)
  notes    String          @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([type])
}

// ─── Categories ────────────────────────────────────────────

model Category {
  id    String @id @default(uuid())
  name  String
  color String
  icon  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Budgets ───────────────────────────────────────────────

model Budget {
  id       String @id @default(uuid())
  category String // category id or "overall"
  amount   Float
  month    String // YYYY-MM

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, month])
}

// ─── Recurring Transactions ────────────────────────────────

enum Frequency {
  daily
  weekly
  monthly
  yearly
}

enum RecurringTag {
  subscription
  bill
  income
  other
}

model RecurringTransaction {
  id          String          @id @default(uuid())
  title       String
  amount      Float
  type        TransactionType
  category    String
  notes       String          @default("")
  frequency   Frequency
  startDate   String?
  nextDueDate String?
  paused      Boolean         @default(false)
  tag         RecurringTag?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Savings Goals ─────────────────────────────────────────

model SavingsGoal {
  id           String  @id @default(uuid())
  name         String
  targetAmount Float
  savedAmount  Float   @default(0)
  color        String
  icon         String
  deadline     String  // ISO date string
  category     String? // linked savings category id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Net Worth ─────────────────────────────────────────────

enum AssetType {
  bank
  investment
  property
  cash
  other
}

enum LiabilityType {
  loan
  credit_card
  mortgage
  other_liability @map("other")
}

model Asset {
  id     String    @id @default(uuid())
  name   String
  amount Float
  type   AssetType
  icon   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Liability {
  id     String        @id @default(uuid())
  name   String
  amount Float
  type   LiabilityType
  icon   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NetWorthSnapshot {
  id          String @id @default(uuid())
  month       String @unique // YYYY-MM
  assets      Float
  liabilities Float
  netWorth    Float

  createdAt DateTime @default(now())
}

// ─── Merchant Map ──────────────────────────────────────────

model MerchantMapping {
  id         String @id @default(uuid())
  merchant   String @unique // lowercase merchant name
  categoryId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Settings ──────────────────────────────────────────────

model Settings {
  id       String @id @default("default")
  theme    String @default("system") // light | dark | system
  currency String @default("৳")     // ৳ | $ | €

  updatedAt DateTime @updatedAt
}

// ─── AI Summary Cache ──────────────────────────────────────

model AiSummary {
  id               String @id @default("default")
  text             String
  generatedAt      String // ISO date
  transactionCount Int

  updatedAt DateTime @updatedAt
}
